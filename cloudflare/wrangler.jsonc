{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nextjs-ui-worker",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-19",
  "workers_dev": false,
  "vars": {
    "API_ENV": "production",
    "CONTAINER_INSTANCE_COUNT": "1"
  },
  "observability": {
    "enabled": true
  },
  "containers": [
    {
      "class_name": "NextjsUI",
      "image": "../Dockerfile",
      "image_build_context": "..",
      "max_instances": 1,
      "instance_type": "basic"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "NEXTJS_UI",
        "class_name": "NextjsUI"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["NextjsUI"]
    }
  ],
  "routes": [
    {
      "pattern": "nextjs.ferozfaiz.com",
      "custom_domain": true
    }
  ],
  "env": {
    "staging": {
      "name": "nextjs-ui-worker-staging",
      "workers_dev": true,
      "preview_urls": false,
      "routes": [],
      "vars": {
        "API_ENV": "production",
        "CONTAINER_INSTANCE_COUNT": "1"
      },
      "observability": {
        "enabled": true
      },
      "containers": [
        {
          "class_name": "NextjsUI",
          "image": "../Dockerfile",
          "image_build_context": "..",
          "max_instances": 1,
          "instance_type": "basic"
        }
      ],
      "durable_objects": {
        "bindings": [
          {
            "name": "NEXTJS_UI",
            "class_name": "NextjsUI"
          }
        ]
      }
    }
  }
}
