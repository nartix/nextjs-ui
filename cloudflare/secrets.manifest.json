{
  "vaultPaths": [
    {
      "path": "kv/data/NEXTJS/NEXTJS-UI",
      "copyAll": true
    },
    {
      "path": "kv/data/GOOGLE_OAUTH",
      "copyAll": true,
      "aliases": {
        "client_id": "GOOGLE_CLIENT_ID",
        "client_secret": "GOOGLE_CLIENT_SECRET",
        "CLIENT_ID": "GOOGLE_CLIENT_ID",
        "CLIENT_SECRET": "GOOGLE_CLIENT_SECRET"
      }
    },
    {
      "path": "kv/data/MICROSOFT_OAUTH",
      "copyAll": true,
      "aliases": {
        "client_id": "MICROSOFT_CLIENT_ID",
        "client_secret": "MICROSOFT_CLIENT_SECRET",
        "CLIENT_ID": "MICROSOFT_CLIENT_ID",
        "CLIENT_SECRET": "MICROSOFT_CLIENT_SECRET"
      }
    }
  ],
  "requiredWorkerSecrets": [
    "NEXT_SECURITY_SECRET",
    "CSRF_SECRET",
    "API_URL_PRODUCTION",
    "API_URL_PREFIX",
    "API_URL_VERSION",
    "NEXTJS_OIDC_CLIENT_ID",
    "NEXTJS_OIDC_CLIENT_SECRET"
  ]
}
